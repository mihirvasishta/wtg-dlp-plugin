# WTG DLP Plugin — environment configuration
#
# Deployment contexts:
#
#   Railway   — set these as Railway environment variables in the dashboard.
#               Railway injects PORT automatically; do NOT set it manually.
#               Leave CERT_PATH and KEY_PATH empty (Railway handles TLS).
#
#   Bastion   — the actual secrets live in /e2open/home/chub/.WTG_Graph_API_Key.env
#               which config.py reads automatically. Copy relevant vars there.
#
#   Local dev — copy this file to .env in the repo root and fill in values.

# -----------------------------------------------------------------------
# Microsoft Graph API — app-only credentials
# Grants access to all shared mailboxes via Mail.ReadWrite application permission
# -----------------------------------------------------------------------
CLIENT_ID=00000000-0000-0000-0000-000000000000
TENANT_ID=00000000-0000-0000-0000-000000000000
CLIENT_SECRET=your-client-secret-here

# -----------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------
HOST=0.0.0.0

# PORT: Railway sets this automatically — do not set it in Railway dashboard.
# For bastion/local dev, set to your desired port (default 8443).
DLP_PORT=8443

# -----------------------------------------------------------------------
# TLS
# -----------------------------------------------------------------------
# Bastion: set these to your certificate paths.
# Railway: leave empty — TLS is terminated at Railway's proxy.
CERT_PATH=
KEY_PATH=

# -----------------------------------------------------------------------
# Paths (relative to the backend/ directory when running main.py)
# -----------------------------------------------------------------------
# Directory containing per-mailbox CSV DLP lists
# File naming: <mailbox-address>.csv  e.g. test-shared@wisetechglobal.com.csv
DLP_LIST_DIR=../config/dlp_lists

# Append-only NDJSON audit log
AUDIT_LOG_PATH=../audit/audit.ndjson
