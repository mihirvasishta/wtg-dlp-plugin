<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<!--
  WTG DLP Plugin — Outlook Add-in Manifest
  ==========================================
  OnMessageSend Smart Alerts add-in for shared mailbox DLP enforcement.

  BEFORE DEPLOYMENT — replace every occurrence of:
    BASTION_HOSTNAME   → the bastion server hostname (e.g. dlp.wisetechglobal.internal)
    BASTION_PORT       → the HTTPS port (e.g. 8443)
    YOUR_GUID_HERE     → a new UUID v4 (generate one at uuidgenerator.net)

  IT prerequisites for each test mailbox:
    1. OWA mailbox policy with OnSendAddinsEnabled = $true
    2. Add-in deployed via M365 Admin Center → Integrated Apps → Upload custom app
    3. TLS certificate on the bastion server (required for OWA to load add-in)
-->
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">

  <!-- ===== Identity ===== -->
  <Id>e4254f3a-2b9a-48c9-abc5-2ae046485486</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>WiseTech Global — Data Operations</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="WTG DLP Check" />
  <Description DefaultValue="Pre-send DLP check for shared mailbox emails. Validates recipient domains and partner references against the partner DLP list." />
  <IconUrl DefaultValue="https://wtg-dlp-plugin-production.up.railway.app/addin/assets/icon-64.png" />
  <HighResolutionIconUrl DefaultValue="https://wtg-dlp-plugin-production.up.railway.app/addin/assets/icon-128.png" />
  <SupportUrl DefaultValue="https://wtg-dlp-plugin-production.up.railway.app/addin/support.html" />

  <AppDomains>
    <AppDomain>https://wtg-dlp-plugin-production.up.railway.app</AppDomain>
  </AppDomains>

  <!-- ===== Hosts ===== -->
  <Hosts>
    <Host Name="Mailbox" />
  </Hosts>

  <!-- ===== Requirements ===== -->
  <Requirements>
    <Sets>
      <!--
        1.8  — getAttachmentContentAsync (read attachment bytes in compose)
        1.12 — Smart Alerts / OnMessageSend event (OWA requirement set)
        The add-in will only activate when both are satisfied.
        OWA (web client) satisfies both; desktop Outlook may not support 1.12 yet.
      -->
      <Set Name="Mailbox" MinVersion="1.8" />
    </Sets>
  </Requirements>

  <!-- ===== Form settings (required by schema) ===== -->
  <FormSettings>
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://wtg-dlp-plugin-production.up.railway.app/addin/taskpane.html" />
      </DesktopSettings>
    </Form>
  </FormSettings>

  <!-- ===== Permissions ===== -->
  <!--
    ReadWriteItem is required to:
    - Read recipients, subject, body in compose mode
    - Call getAttachmentContentAsync to read attachment bytes
    - Write to roaming settings
  -->
  <Permissions>ReadWriteItem</Permissions>

  <!-- ===== Rule (legacy — required alongside VersionOverrides) ===== -->
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit" />
  </Rule>

  <!-- ===== VersionOverrides — Smart Alerts (OnMessageSend) ===== -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.1" xsi:type="VersionOverridesV1_1">

      <Requirements>
        <bt:Sets>
          <bt:Set Name="Mailbox" MinVersion="1.12" />
        </bt:Sets>
      </Requirements>

      <Hosts>
        <Host xsi:type="MailHost">

          <!-- SupportsSharedFolders: REQUIRED for shared mailbox event interception -->
          <SupportsSharedFolders>true</SupportsSharedFolders>

          <DesktopFormFactor>

            <!-- Function file — hosts the OnMessageSend event handler -->
            <FunctionFile resid="LaunchEvent.Url" />

            <!-- Task pane — shows violation detail cards -->
            <ExtensionPoint xsi:type="MessageComposeCommandSurface">
              <OfficeTab id="TabDefault">
                <Group id="msgComposeGroup">
                  <Label resid="GroupLabel" />
                  <Control xsi:type="Button" id="dlpTaskpaneButton">
                    <Label resid="TaskpaneButton.Label" />
                    <Supertip>
                      <Title resid="TaskpaneButton.Label" />
                      <Description resid="TaskpaneButton.Tooltip" />
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="Icon.16x16" />
                      <bt:Image size="32" resid="Icon.32x32" />
                      <bt:Image size="80" resid="Icon.80x80" />
                    </Icon>
                    <Action xsi:type="ShowTaskpane">
                      <SourceLocation resid="Taskpane.Url" />
                    </Action>
                  </Control>
                </Group>
              </OfficeTab>
            </ExtensionPoint>

            <!-- Smart Alerts — OnMessageSend event -->
            <ExtensionPoint xsi:type="LaunchEvent">
              <LaunchEvents>
                <LaunchEvent
                  Type="OnMessageSend"
                  FunctionName="onMessageSendHandler"
                  SendMode="PromptUser" />
                  <!--
                    SendMode="PromptUser":
                      - Warn violations: OWA shows "Send Anyway" / "Don't Send"
                      - Block violations: add-in omits sendModeOverride → only "Don't Send"

                    Alternative: SendMode="Block" (always hard-block; no override possible)
                    For prototype, PromptUser lets analysts consciously override warnings.
                  -->
              </LaunchEvents>
              <SourceLocation resid="LaunchEvent.Url" />
            </ExtensionPoint>

          </DesktopFormFactor>
        </Host>
      </Hosts>

      <Resources>
        <!-- URLs — all served from the bastion HTTPS server -->
        <bt:Urls>
          <bt:Url id="LaunchEvent.Url"
                  DefaultValue="https://wtg-dlp-plugin-production.up.railway.app/addin/launchevent.html" />
          <bt:Url id="Taskpane.Url"
                  DefaultValue="https://wtg-dlp-plugin-production.up.railway.app/addin/taskpane.html" />
        </bt:Urls>

        <!-- Short strings -->
        <bt:ShortStrings>
          <bt:String id="GroupLabel"           DefaultValue="DLP Check" />
          <bt:String id="TaskpaneButton.Label"  DefaultValue="DLP Violations" />
          <bt:String id="TaskpaneButton.Tooltip"
                     DefaultValue="View DLP violation details for this email." />
        </bt:ShortStrings>

        <!-- Long strings (not used here but schema requires the section) -->
        <bt:LongStrings>
          <bt:String id="TaskpaneButton.Description"
                     DefaultValue="Shows detailed DLP violation cards for the current email." />
        </bt:LongStrings>

        <!-- Icons — placeholder URLs; replace with real icon files -->
        <bt:Images>
          <bt:Image id="Icon.16x16"  DefaultValue="https://wtg-dlp-plugin-production.up.railway.app/addin/assets/icon-16.png" />
          <bt:Image id="Icon.32x32"  DefaultValue="https://wtg-dlp-plugin-production.up.railway.app/addin/assets/icon-32.png" />
          <bt:Image id="Icon.80x80"  DefaultValue="https://wtg-dlp-plugin-production.up.railway.app/addin/assets/icon-80.png" />
        </bt:Images>
      </Resources>

    </VersionOverrides>
  </VersionOverrides>

</OfficeApp>
